rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile docs: owner can create/read/update/delete their own doc.
    // Admins can list users (for admin management screens).
    match /users/{userId} {
      allow create, read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.token.admin == true;
    }

    // Admin-only collection
    match /adminData/{docId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Public collection example
    match /public/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
