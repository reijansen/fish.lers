# Express server
PORT=5000
NODE_ENV=development

# Firebase Admin Config (from your Firebase console)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com

# CORS - Frontend URL
CLIENT_URL=http://localhost:5173
# Optional additional frontend origins (comma-separated)
# CLIENT_URLS=http://localhost:5174,http://127.0.0.1:5173

# MongoDB connection string (replace with your actual connection string)
MONGODB_URI=your-mongodb-connection-string

# Lightweight request metrics logging (per interval)
REQUEST_METRICS_ENABLED=true
REQUEST_METRICS_INTERVAL_MS=60000
REQUEST_METRICS_TOP_N=10
